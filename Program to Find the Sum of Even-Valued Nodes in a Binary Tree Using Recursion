class Node
 {
    int data;
    Node left;
    Node right;
    Node(int u){
        this.data=u;
        this.left=null;
        this.right=null;
    }
    static int sumeven(Node root)
    {
        if(root == null){
            return 0;
        }
        if((root.data)%2==0){
            return root.data+sumeven(root.left)+sumeven(root.right);
        }
        else{
            return sumeven(root.left)+sumeven(root.right);
        }
    }
    public static void main(String[] args) {
        Node root=new Node(10);
        root.left=new Node(5);
        root.right=new Node(15);
        root.left.right=new Node(7);
        root.left.right.left=new Node(6);
        root.left.right.right=new Node(8);
        System.out.print("SUM of even:"+sumeven(root));
    }
}
