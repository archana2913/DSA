import java.util.*;
class Test{
    static int m1(int n){
        if(n<0){
            return 0;
        }
        else if(n==1){
            return 1;
        }
        else if(n%2==0){
            return n*m1(n-1);
        }
        else{
            return m1(n-1);
        }
    }
    public static void main(String args[]){
        Scanner sc=new Scanner(System.in);
        System.out.print("enter a number:");
        int n=sc.nextInt();
        System.out.print(Test.m1(n));
    }
}
